<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HackStreak" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">#0D1117</item>
        <item name="android:navigationBarColor">#0D1117</item>
        <item name="android:windowBackground">@color/thm_dark_bg</item>
    </style>

    <style name="Theme.HackStreak.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.HackStreak</item>
    </style>
</resources>
